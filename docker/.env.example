# ------------------------------
# Environment Variables for Nginx reverse proxy
# ------------------------------
NGINX_SERVER_NAME=app.classhorse.top
NGINX_HTTPS_ENABLED=true
NGINX_SSL_PORT=443
NGINX_SSL_CERT_FILENAME=/etc/nginx/ssl/fullchain.pem
NGINX_SSL_CERT_KEY_FILENAME=/etc/nginx/ssl/privkey.pem
NGINX_SSL_PROTOCOLS=TLSv1.2 TLSv1.3

# ------------------------------
# Certbot Configuration
# ------------------------------
CERTBOT_EMAIL=your_email@example.com
CERTBOT_DOMAIN=app.classhorse.top

# ------------------------------
# AWS S3 Configuration
# ------------------------------
S3_USE_AWS_MANAGED_IAM=false

# ------------------------------
# Docker Compose Service Expose Ports
# ------------------------------
EXPOSE_NGINX_PORT=8091
EXPOSE_NGINX_SSL_PORT=443

# 其他保持原有配置不变...
（保留文件原有内容，仅修改上述关键配置项）
